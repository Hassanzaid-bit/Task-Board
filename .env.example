# Copy to .env and adjust as needed. docker compose reads this file automatically.

# --- PostgreSQL ---
POSTGRES_USER=taskboard
POSTGRES_PASSWORD=taskboard_dev_password
POSTGRES_DB=taskboard
# Used by the backend to connect. Inside docker compose the host is "db";
# for a backend running directly on your machine use localhost.
DATABASE_URL=postgresql+asyncpg://taskboard:taskboard_dev_password@db:5432/taskboard

# --- Backend ---
# Secret used to sign JWTs. Generate a real one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-real-deployments
# Access-token lifetime in minutes (no refresh-token rotation yet)
JWT_EXPIRES_MINUTES=480

# --- Frontend ---
# Where the vite dev server proxies /api and /ws requests.
# Inside docker compose this is the backend service; outside it, localhost.
VITE_PROXY_TARGET=http://backend:8000
